{
    "name": "@arkitektum/altinn-studio-custom-components",
    "version": "15.3.6",
    "description": "Custom components for Altinn Studio",
    "main": "dist/main.js",
    "module": "dist/main.js",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "symlinks": "node scripts/create-symlinks.js",
        "copy-dist-resources": "copyfiles --flat src/data/resource.*.json src/data/resources.json dist",
        "test": "jest",
        "build": "yarn symlinks && NODE_ENV=production webpack && yarn copy-dist-resources",
        "start": "yarn symlinks && webpack serve --config webpack.config.dev.js",
        "lint": "eslint src --ext .js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Arkitektum/altinn-studio-custom-components.git"
    },
    "author": "",
    "bugs": {
        "url": "https://github.com/Arkitektum/altinn-studio-custom-components/issues"
    },
    "homepage": "https://github.com/Arkitektum/altinn-studio-custom-components#readme",
    "devDependencies": {
        "@babel/preset-env": "^7.29.2",
        "@eslint/js": "^10.0.1",
        "copyfiles": "^2.4.1",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.2.0",
        "dotenv": "^17.4.2",
        "dotenv-webpack": "^9.0.0",
        "eslint": "^10.2.1",
        "globals": "^17.5.0",
        "html-webpack-plugin": "^5.6.7",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jsdom": "^29.1.0",
        "mini-css-extract-plugin": "^2.10.2",
        "prettier": "3.8.3",
        "style-loader": "^4.0.0",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.3"
    },
    "packageManager": "yarn@4.10.3",
    "dependencies": {
        "@arkitektum/altinn-studio-custom-components-utils": "^1.4.2"
    }
}
