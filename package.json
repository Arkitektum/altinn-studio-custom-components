{
    "name": "@arkitektum/altinn-studio-custom-components",
    "version": "13.10.2",
    "description": "Custom components for Altinn Studio",
    "main": "dist/main.js",
    "module": "dist/main.js",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "symlinks": "node scripts/create-symlinks.js",
        "copy-dist-resources": "copyfiles --flat src/data/resource.nb.json dist",
        "copy-docs-resources": "copyfiles --flat src/data/resource.nb.json docs/data",
        "test": "jest",
        "api": "node api/index.mjs",
        "build": "yarn symlinks && webpack --mode production && yarn copy-dist-resources",
        "build-docs": "yarn symlinks && webpack --mode production --config webpack.config.docs.js && yarn copy-docs-resources",
        "start": "yarn symlinks && webpack serve --mode development --config webpack.config.dev.js",
        "start-docs": "yarn symlinks && webpack serve --mode development --config webpack.config.docs.js",
        "lint": "eslint src --ext .js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Arkitektum/altinn-studio-custom-components.git"
    },
    "author": "",
    "bugs": {
        "url": "https://github.com/Arkitektum/altinn-studio-custom-components/issues"
    },
    "homepage": "https://github.com/Arkitektum/altinn-studio-custom-components#readme",
    "devDependencies": {
        "@babel/preset-env": "^7.29.2",
        "@eslint/js": "^10.0.1",
        "copyfiles": "^2.4.1",
        "cors": "^2.8.6",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.2.0",
        "dotenv": "^17.3.1",
        "eslint": "^10.0.3",
        "express": "^5.2.1",
        "fast-xml-parser": "^5.5.6",
        "globals": "^17.4.0",
        "highlight.js": "^11.11.1",
        "html-webpack-plugin": "^5.6.6",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "jsdom": "^29.0.0",
        "libxmljs2": "^0.37.0",
        "mini-css-extract-plugin": "^2.10.1",
        "prettier": "3.8.1",
        "style-loader": "^4.0.0",
        "webpack": "^5.105.4",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.3"
    },
    "packageManager": "yarn@4.10.3",
    "dependencies": {
        "@arkitektum/altinn-studio-custom-components-utils": "^1.2.0"
    }
}
